# ============================================================
#  Mugiwara Store — Variáveis de Ambiente (exemplo)
#  Copie este arquivo para `.env` e ajuste os valores.
# ============================================================

# ---- Banco de Dados (PostgreSQL) ----
POSTGRES_USER=mugiwara
POSTGRES_PASSWORD=grandline2026
POSTGRES_DB=mugiwara_store
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL de conexão usada pelo backend (montada a partir das variáveis acima).
# Em execução via Docker Compose, o host é o nome do serviço: `db`.
DATABASE_URL=postgresql+psycopg2://mugiwara:grandline2026@db:5432/mugiwara_store

# ---- Segurança / JWT ----
# Gere uma chave forte em produção: `openssl rand -hex 32`
SECRET_KEY=troque-esta-chave-em-producao-0d5f3b8a9c1e2f4a6b8d0c2e4f6a8b0d
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALGORITHM=HS256

# ---- Aplicação ----
PROJECT_NAME=Mugiwara Store
API_V1_PREFIX=/api
# Origens permitidas para CORS (separadas por vírgula)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost

# ---- Frontend ----
# URL base da API consumida pelo frontend (Vite)
VITE_API_URL=http://localhost:8000/api
